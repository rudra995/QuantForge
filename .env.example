# ==============================================================================
# QuantForge Environment Configuration Template
# ==============================================================================

# Application Environment: 'dev' or 'prod'
ENV=dev

# Logging Configuration
# Supported levels: debug, info, warning, error, critical
LOG_LEVEL=info

# Database Settings (asyncpg for PostgreSQL asynchronous support)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/quantforge

# Redis Settings
REDIS_URL=redis://localhost:6379/0
